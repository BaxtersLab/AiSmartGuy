{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AiSmartGuy",
  "version": "0.1.0",
  "identifier": "com.aismartguy.app",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "splash",
        "url": "splash.html",
        "title": "AiSmartGuy",
        "width": 800,
        "height": 250,
        "decorations": false,
        "resizable": false,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "main",
        "url": "index.html",
        "title": "AiSmartGuy",
        "width": 960,
        "height": 800,
        "minWidth": 720,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
